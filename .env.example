# Copy this file to .env before docker compose deployment.

# Local-only default:
DOC_HUB_BIND_ADDR=127.0.0.1
DOC_HUB_PORT=8787
DOC_HUB_ORIGIN=http://localhost:8787,http://127.0.0.1:8787

# LAN access example. Use this if other devices on the same network should access Doc-Hub.
# DOC_HUB_BIND_ADDR=0.0.0.0
# DOC_HUB_ORIGIN=*

# Public deployment example:
# DOC_HUB_BIND_ADDR=0.0.0.0
# DOC_HUB_PORT=8787
# DOC_HUB_ORIGIN=https://docs.example.com

# Must be changed before any shared or public deployment.
DOC_HUB_JWT_SECRET=change-this-internal-secret-before-sharing

# 0 enables first admin registration. Change to 1 after creating the admin account.
DOC_HUB_DISABLE_REGISTER=0

# Share links expire after this many hours. 720 = 30 days.
DOC_HUB_SHARE_TTL_HOURS=720
