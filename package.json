{
  "name": "doc-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Doc-Hub · 内部文档管理与分享平台（Go + React）一键启动脚本",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta -k --kill-others-on-fail \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cd apps/api && go run ./cmd/server",
    "dev:web": "cd apps/web && npm run dev",

    "build": "npm run build:web && npm run build:api",
    "build:api": "cd apps/api && go build -o ../../dist/doc-hub-server ./cmd/server",
    "build:web": "cd apps/web && npm run build",

    "start": "./dist/doc-hub-server",

    "install:all": "npm install && cd apps/web && npm install",
    "clean": "rm -rf dist apps/web/dist apps/web/node_modules"
  },
  "devDependencies": {
    "concurrently": "latest"
  },
  "engines": {
    "node": ">=18",
    "go": ">=1.21"
  }
}
